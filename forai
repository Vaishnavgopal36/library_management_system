## docker-compose.yml

```yaml
version: '3.8'

services:
  # Database (PostgreSQL)
  db:
    # Use a lightweight PostgreSQL image. The init.sql will create tables and seed data on first run.
    image: postgres:15-alpine
    # Mount a volume for data persistence and to run initialization scripts
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./db/init.sql:/docker-entrypoint-initdb.d/init.sql
    environment:
    # Set environment variables for PostgreSQL. These will be used to create the initial database and user.
      - POSTGRES_USER=admin
      - POSTGRES_PASSWORD=securepassword
      - POSTGRES_DB=library_db
      # Expose the default PostgreSQL port
    networks:
      - library_network

  # Backend API (FastAPI)
  
  backend:
    build: ./backend
    ports:
      - "8080:8080" # Spring Boot default port
    env_file:
      - .env
  
    depends_on:
      - db
      - redis
    environment:
      # Spring Boot uses standard JDBC URLs
      - SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/library_db
      - SPRING_DATASOURCE_USERNAME=admin
      - SPRING_DATASOURCE_PASSWORD=securepassword
      # Best Practice: Use Flyway/Liquibase for migrations, set Hibernate to validate against the existing schema
      - SPRING_JPA_HIBERNATE_DDL_AUTO=validate
      - SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
      - REDIS_HOST=redis
      - REDIS_PORT=6379
    networks:
      - library_network
  # Frontend (React + Vite)
  frontend:
    build: ./frontend
    # In dev, install deps into container volume before starting Vite.
    command: sh -c "npm install && npm run dev -- --host"
    # Mount the frontend code and node_modules. The --host flag allows Vite to be accessible from outside the container.
    volumes:
      - ./frontend:/app
      - /app/node_modules # Prevent host node_modules from overriding container
    ports:
      - "5173:5173"
    environment:
      - VITE_API_URL=http://localhost:8080 # Browser talks to localhost
    networks:
      - library_network

  # Redis (for caching)
  redis:
    image: redis:alpine
    networks:
      - library_network

volumes:
  postgres_data:

networks:
# Define a custom network for our services to communicate securely
  library_network:
    driver: bridge # Use the default bridge network driver for simplicity

```

