    @Transactional(readOnly = true)
    public List<FineResponse> getGlobalLedger() {
        return getGlobalLedger(null, null, null, null, null, null);
    }

    @Transactional(readOnly = true)
    public List<FineResponse> getGlobalLedger(
            UUID fineId,
            UUID userId,
            UUID transactionId,
            Boolean isPaid,
            BigDecimal minAmount,
            BigDecimal maxAmount
    ) {
