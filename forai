          <a href="https://react.dev" target="_blank" rel="noreferrer">
            <img
              src={reactLogo}
              className="h-20 w-20 transition hover:scale-110 motion-safe:animate-[spin_20s_linear_infinite]"
              alt="React logo"
            />
          </a>
        </div>
        <h1 className="text-4xl font-bold">Vite + React</h1>
        <div className="rounded-xl border border-slate-700 bg-slate-900/70 p-6">
          <button
            className="rounded-lg bg-cyan-500 px-4 py-2 font-semibold text-slate-950 transition hover:bg-cyan-400"
            onClick={() => setCount((count) => count + 1)}
          >
            count is {count}
          </button>
          <p className="mt-4 text-slate-300">
            Edit <code>src/App.tsx</code> and save to test HMR
          </p>
        </div>
        <p className="text-slate-400">Click on the Vite and React logos to learn more</p>
      </div>
    </main>
  )
}

export default App

