  const returnedCol: Column<Transaction> = {
    header: 'Returned',
    accessor: 'returnedDate',
    render: (row) => (
      <span style={{ color: row.returnedDate ? '#111827' : '#9ca3af' }}>
        {row.returnedDate ? fmtDate(row.returnedDate) : '—'}
