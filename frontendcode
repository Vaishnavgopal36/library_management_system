    setTimeout(() => { returnModal.close(); }, 1000);
  };

  const fineAmount = (returnModal.data?.daysOverdue ?? 0) * FINE_RATE_PER_DAY;

  // ── Stat counts for summary chips ──
  const counts = {
    Issued:   baseData.filter(t => t.status === 'Issued').length,
