    const matchesSearch = !query ||
      book.title.toLowerCase().includes(query) ||
      book.authors.some(a => a.name.toLowerCase().includes(query)) ||
      book.isbn.includes(query) ||
      book.categories.some(c => c.name.toLowerCase().includes(query));
