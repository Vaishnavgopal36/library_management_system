  const actionCol: Column<Transaction> = {
    header: 'Action',
    accessor: 'id',
    render: (row) =>
      row.status === 'Issued' || row.status === 'Overdue' ? (
        <Button size="sm" variant="secondary" onClick={() => returnModal.open(row)}>
