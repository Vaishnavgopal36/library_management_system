      ) : (
        <span style={{ color: '#9ca3af', fontSize: '0.8125rem' }}>—</span>
      ),
  };

  // Admin: Book | Member | Issued | Due | Returned | Status | Action
  // Member: Book | Issued | Due | Returned | Status | Fine
  const fineCol: Column<Transaction> = {
    header: 'Fine',
    accessor: 'daysOverdue',
